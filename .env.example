# ═══════════════════════════════════════════════
#  RAG Ingestion Pipeline — Configuration
# ═══════════════════════════════════════════════

DEBUG=true
LOG_LEVEL=INFO

# ── Azure Document Intelligence (REQUIRED) ──
AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DI_KEY=your-key-here

# ── Azure OpenAI (REQUIRED for embeddings + image summarization) ──
AZURE_OPENAI_API_KEY=your-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ── Chunking ──
CHUNK_SIZE=3000
CHUNK_OVERLAP=200

# ── Image Processing ──
IMAGE_MODE=base64
# MIN_PIXEL_AREA=10000       # min pixel area to keep an image (100×100 = 10000)
# PPTX_BG_THRESHOLD=0.85     # bbox coverage fraction → background (drop)
# PPTX_LOGO_SIZE_KB=50       # bytes below this + no text/shapes → logo (drop)
